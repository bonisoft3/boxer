{
  "compose": {},
  "dockerfile": {
    "preamble": [
      "COPY --from=bonitao/lazybox:0.8.0@sha256:98414753b9ae2e90b096a1e3a9f7598ac2477e10fa3e5384083d9e29dde3c499 /lazybox/ /root/.local/share/lazybox/",
      "ENV PATH=/root/.local/bin:/root/.local/share/lazybox/bin:$PATH",
      "ENV MISE_TRUSTED_CONFIG_PATHS=/monorepo"
    ],
    "secrets": [],
    "from": {
      "ref": ":build",
      "name": "services_boxer-build",
      "context": "service:services_boxer-build"
    },
    "mounts": [],
    "epilogue": [],
    "expose": [],
    "entrypoint": null,
    "incremental": false
  },
  "name": "integrate",
  "project": "services_boxer",
  "dir": "services/boxer",
  "activate": "mise x --",
  "srcs": {
    "globs": [
      "tests/**/*"
    ],
    "exclude": []
  },
  "outs": {
    "globs": [
      "target/debug/deps/*-*"
    ],
    "exclude": []
  },
  "env": {},
  "taskfile": {
    "run": "when_changed",
    "silent": false,
    "preconditions": []
  },
  "visibility": "internal",
  "deps": [
    "build"
  ],
  "transitiveDeps": [
    "build",
    "setup"
  ],
  "transitiveCrossDeps": [],
  "chainedDeps": [
    {
      "name": "build",
      "project": "services_boxer",
      "dir": "services/boxer",
      "outs": {
        "globs": [
          "target/debug/boxer"
        ],
        "exclude": []
      }
    }
  ],
  "cmds": [
    {
      "srcs": {
        "globs": [
          "tests/**/*"
        ],
        "exclude": [],
        "defaultGlobs": null,
        "defaultExclude": null
      },
      "do": "cargo test --tests",
      "dockerfile": {
        "wrap": ""
      },
      "name": "builtin",
      "shell": "exec",
      "stop": false
    }
  ],
  "cache": {
    "full": false,
    "similar": false
  }
}